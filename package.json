{
  "name": "@xgsd/cli",
  "description": "Local workflow orchestration for solo-developers, built on top of xGSD. Get started in minutes. Create an action, define a workflow, and xgsd run it!",
  "version": "0.7.0-beta.0",
  "author": "Michael Palmer",
  "bin": {
    "xgsd": "./bin/run.js"
  },
  "backend": "https://backend-dev.xgsd.io",
  "bugs": "https://github.com/Isolated-/xgsd-cli/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5.4.63",
    "@oclif/plugin-version": "^2.2.32",
    "@types/js-yaml": "^4.0.9",
    "@xgsd/runtime": "0.1.4",
    "chalk": "^5.6.0",
    "esbuild": "0.28.0",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.8.5",
    "fs-extra": "^11.3.1",
    "joi": "^18.0.1",
    "js-yaml": "^4.1.1",
    "ms": "^2.1.3",
    "pretty-bytes": "^7.0.1",
    "pretty-ms": "^9.3.0",
    "treeify": "^1.1.0",
    "ts-deepmerge": "^7.0.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^18",
    "@types/treeify": "^1.0.3",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "jest": "^30.1.1",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@xgsd/runtime": "^0.1.2",
    "esbuild": "^0.28.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "@xgsd/runtime": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./templates",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/Isolated-/xgsd-cli",
  "keywords": [
    "xgsd",
    "cli",
    "workflow for Node.js",
    "xgsd workflows",
    "oclif",
    "serverless",
    "workflow",
    "orchestration",
    "nodejs",
    "cli"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "oclif": {
    "bin": "xgsd",
    "dirname": "xgsd",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-version",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "repository": "https://github.com/Isolated-/xgsd-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "test": "jest",
    "test:watch": "jest --watch",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
